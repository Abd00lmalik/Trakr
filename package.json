{
  "name": "trakr",
  "version": "0.1.0",
  "private": true,
  "description": "Trakr is an AI-powered A2MCP opportunity companion for personalized recommendations.",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/copy-pdf-worker.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:service1:production": "node scripts/service1-production-journeys.mjs",
    "smoke:service2:production": "node scripts/service2-production-smoke.mjs",
    "smoke:service3:production": "node scripts/service3-production-smoke.mjs",
    "test:privacy": "tsx --test tests/privacy-logging.test.ts",
    "test:verification": "tsx --test tests/source-verification.test.ts",
    "test:inventory-monitoring": "tsx --test tests/inventory-monitoring.test.ts",
    "test:inventory-metadata": "tsx --test tests/opportunity-metadata.test.ts tests/grants-gov-normalization.test.ts",
    "test:devpost": "tsx --test tests/devpost-normalization.test.ts",
    "test:greenhouse": "tsx --test tests/greenhouse-normalization.test.ts",
    "test:ashby": "tsx --test tests/ashby-normalization.test.ts",
    "test:ranking": "tsx --test tests/ranking-evaluation.test.ts",
    "test:service1": "tsx --test tests/service1-opportunity-finding.test.ts",
    "test:service2": "tsx --test tests/service2-resume-intelligence.test.ts",
    "test:service2:calibration": "tsx --test tests/service2-calibration-corpus.test.ts",
    "test:service3": "tsx --test tests/service3-resume-generation.test.ts",
    "test:workspace": "tsx --test tests/workspace.test.ts",
    "test:companion": "tsx --test tests/conversational-asp.test.ts",
    "devpost:compare": "tsx scripts/compare-devpost-normalization.ts",
    "evaluate:ranking": "tsx scripts/evaluate-ranking.ts",
    "evaluate:inventory-monitoring": "tsx scripts/evaluate-inventory-monitoring.ts",
    "verify": "npm run test:privacy && npm run test:verification && npm run test:inventory-monitoring && npm run test:inventory-metadata && npm run test:devpost && npm run test:greenhouse && npm run test:ashby && npm run test:ranking && npm run test:service1 && npm run test:service2 && npm run test:service2:calibration && npm run test:service3 && npm run test:workspace && npm run test:companion && npm run calibration:gate && npm run typecheck && npm run lint && npm run build && npm run smoke",
    "calibration:generate": "tsx scripts/generate-resume-calibration-corpus.ts",
    "calibration:validate-reviews": "tsx scripts/validate-resume-calibration-reviews.ts",
    "calibration:prepare-adjudication": "tsx scripts/prepare-resume-calibration-adjudication.ts",
    "calibration:validate-adjudications": "tsx scripts/validate-resume-calibration-adjudications.ts",
    "calibration:merge-adjudications": "tsx scripts/merge-resume-calibration-adjudications.ts",
    "calibration:run": "tsx scripts/run-resume-calibration.ts",
    "calibration:gate": "tsx scripts/run-resume-calibration.ts --gate",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "ingest": "node scripts/ingest.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@types/pg": "^8.15.6",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.5",
    "next": "^15.5.7",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^24.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "docx": "^9.7.1",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.7",
    "eslint-config-prettier": "^10.1.8",
    "pdfkit": "^0.19.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
