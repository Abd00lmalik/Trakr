{
  "name": "trakr",
  "version": "0.1.0",
  "private": true,
  "description": "Trakr is an AI-powered A2MCP opportunity companion for personalized recommendations.",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/copy-pdf-worker.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-test.mjs",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run smoke",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "ingest": "node scripts/ingest.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@types/pg": "^8.15.6",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.5",
    "next": "^15.5.7",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^24.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "docx": "^9.7.1",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.7",
    "eslint-config-prettier": "^10.1.8",
    "pdfkit": "^0.19.1",
    "typescript": "^5.9.3"
  }
}
