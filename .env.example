# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
TRAKR_SERVICE_URL=http://localhost:3000

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# PostgreSQL with pgvector enabled
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trakr

# Optional runtime tuning
RECOMMENDATION_LIMIT=7
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RECOMMENDATION_LOG_RETENTION_DAYS=30
RECOMMENDATION_LOG_HASH_KEY=

# Optional public endpoint guard. Leave empty for free OKX A2MCP review.
TRAKR_API_KEY=
INGEST_API_KEY=
TRAKR_ADMIN_API_KEY=
